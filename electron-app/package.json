{
  "name": "logistics-intelligence-platform",
  "version": "1.0.0",
  "description": "Logistics Intelligence Platform Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "build": "npm run react-build && electron-builder"
  },

  "build": {
    "appId": "com.logistics.intelligence",
    "productName": "Logistics Intelligence Platform",
    "extraMetadata": {
      "main": "main.js"
    },
    
    "directories": {
      "output": "dist",
      "buildResources": "assets" 
    },

    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "../data",
        "to": "data",
        "filter": ["*.db"]
      },
      {
        "from": "../ml/models",
        "to": "ml/models"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version"]
  },
  "homepage": "./"
}